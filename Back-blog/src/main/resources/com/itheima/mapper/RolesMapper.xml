<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itheima.mapper.RolesMapper"><!--映射路径文件-->
    <!--动态sql分页查询，查询频繁，故而以xml配置-->
    <!--xml映射文件包名要与mapper一样-->
<!--    <cache eviction="LRU" flushInterval="60000" size="1024" readOnly="true"/>-->
    <select id="list" resultType="com.itheima.pojo.Roles">
        select * from roles
        <where>
            <if test="roleName != null">
               role_name = #{roleName}
            </if>
            <if test="roleDescription != null">
                and role_description = #{roleDescription}
            </if>
        </where>
    </select>

    <select id="userRolesList" resultType="com.itheima.pojo.UserRoles">
        select * from user_roles ur
        <where>
            <if test="userId != null">
                user_id = #{userId}
            </if>
            <if test="roleId != null">
                and role_id = #{roleId}
            </if>
        </where>
    </select>
</mapper>